{
  "name": "drone-spatial-qa-framework",
  "version": "1.0.0",
  "description": "Production-grade Playwright + PostGIS automation framework for Autonomous Drone-Delivery spatial validation",
  "author": "Senior SDET",
  "license": "MIT",
  "scripts": {
    "test": "npx playwright test",
    "test:api": "npx playwright test tests/specs/telemetryApi.spec.ts",
    "test:geo": "npx playwright test tests/specs/geofencing.spec.ts",
    "test:path": "npx playwright test tests/specs/pathDeviation.spec.ts",
    "test:integrity": "npx playwright test tests/specs/dbToUiIntegrity.spec.ts",
    "test:headed": "npx playwright test --headed",
    "report": "allure generate allure-results --clean -o allure-report && allure open allure-report",
    "api:start": "ts-node src/api/server.ts",
    "api:dev": "nodemon --watch src/api --exec ts-node src/api/server.ts",
    "lint": "eslint 'tests/**/*.ts' 'src/**/*.ts' --fix",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down -v",
    "docker:logs": "docker compose logs -f"
  },
  "dependencies": {
    "@turf/turf": "^6.5.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-async-errors": "^3.1.1",
    "express-validator": "^7.2.0",
    "pg": "^8.12.0",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.2",
    "@types/pg": "^8.11.6",
    "@types/turf": "^3.5.32",
    "@typescript-eslint/eslint-plugin": "^7.12.0",
    "@typescript-eslint/parser": "^7.12.0",
    "allure-playwright": "^3.0.0-beta.5",
    "eslint": "^8.57.0",
    "nodemon": "^3.1.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
