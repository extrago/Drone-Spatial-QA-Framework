# ─── Database ──────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=dronedb
DB_USER=postgres
DB_PASSWORD=postgres

# ─── API Server ────────────────────────────────────────────────────────────────
API_PORT=3001
API_BASE_URL=http://localhost:3001

# ─── UI Server ─────────────────────────────────────────────────────────────────
UI_BASE_URL=http://localhost:8080

# ─── Test Configuration ────────────────────────────────────────────────────────
# Maximum allowed path deviation in meters (Turf.js assertion)
MAX_PATH_DEVIATION_METERS=5

# Geofence poll interval on the UI (ms) — must match app.js POLL_INTERVAL
UI_POLL_INTERVAL_MS=2000
